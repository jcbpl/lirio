<div class="max-w-2xl mx-auto px-4 pt-4"
     data-controller="album-detail cover-art"
     data-album-detail-external-id-value="<%= @album.external_id %>"
     data-album-detail-tracks-synced-value="<%= @album.tracks_synced? %>"
     data-album-detail-source-id-value="<%= @album.library.source_id %>"
     data-cover-art-source-id-value="<%= @album.library.source_id %>">

  <%# Back button %>
  <div class="mb-4">
    <%= link_to root_path, class: "inline-flex items-center text-text-secondary hover:text-text-primary transition-colors", data: { turbo_action: "restore" } do %>
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    <% end %>
  </div>

  <%# Album artwork %>
  <div class="flex justify-center mb-4">
    <div class="w-64 h-64 rounded overflow-hidden bg-surface-raised shadow-2xl relative">
      <div data-cover-art-target="fallback"
           class="absolute inset-0 flex items-center justify-center text-text-tertiary">
        <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V4.5A2.25 2.25 0 0016.5 2.25h-.378a2.25 2.25 0 00-2.163 1.632l-.756 2.646M9 9v10.969" />
        </svg>
      </div>
      <img data-cover-art-target="image"
           data-cover-art-id="<%= @album.cover_art_id %>"
           data-action="load->cover-art#fadeIn"
           alt="<%= @album.title %>"
           class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300"
           data-size="640">
    </div>
  </div>

  <%# Album metadata %>
  <div class="text-center mb-6">
    <% if @album.year %>
      <span class="text-xs text-text-secondary font-medium uppercase tracking-wider"><%= @album.year %></span>
    <% end %>
    <h1 class="text-2xl font-bold mt-1"><%= @album.title %></h1>
    <p class="text-base text-text-secondary mt-1"><%= @album.artist %></p>
  </div>

  <%# Action row %>
  <div class="flex items-center justify-between mb-6 px-2">
    <div class="flex items-center gap-4">
      <span class="text-xs text-text-tertiary">
        <%= pluralize(@album.song_count, "song") %><% if @album.duration_seconds > 0 %> · <%= formatted_duration(@album.duration_seconds) %><% end %>
      </span>
    </div>
    <div class="flex items-center gap-3">
      <button class="w-12 h-12 rounded-full bg-accent flex items-center justify-center opacity-50 cursor-default" disabled>
        <svg class="w-6 h-6 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z" />
        </svg>
      </button>
    </div>
  </div>

  <%# Track list %>
  <div id="track-list" data-album-detail-target="trackList">
    <% if @album.tracks_synced? %>
      <% @album.tracks.each do |track| %>
        <%= render "albums/track", track: track %>
      <% end %>
    <% else %>
      <div data-album-detail-target="loadingState" class="py-8 text-center">
        <div class="inline-flex items-center gap-2 text-text-secondary">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span>Syncing tracks...</span>
        </div>
      </div>
    <% end %>
  </div>
</div>
