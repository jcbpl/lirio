<div class="max-w-md mx-auto px-6 pt-16"
     data-controller="setup">
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Welcome to Lirio</h1>
    <p class="text-text-secondary">Connect your Navidrome library to get started.</p>
  </div>

  <%= form_with model: @library, class: "space-y-5", data: { action: "submit->setup#submit" } do |f| %>
    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1.5">Library Name</label>
      <%= f.text_field :name,
        value: "My Library",
        class: "w-full bg-surface-raised border border-divider rounded-xl px-4 py-3 text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent",
        required: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1.5">Navidrome URL</label>
      <%= f.url_field :source_url,
        placeholder: "http://192.168.1.50:4533",
        required: true,
        class: "w-full bg-surface-raised border border-divider rounded-xl px-4 py-3 text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent",
        data: { setup_target: "sourceUrl" } %>
    </div>

    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1.5">Username</label>
      <input type="text"
             data-setup-target="username"
             placeholder="username"
             autocomplete="username"
             class="w-full bg-surface-raised border border-divider rounded-xl px-4 py-3 text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent">
    </div>

    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1.5">Password</label>
      <input type="password"
             data-setup-target="password"
             placeholder="password"
             autocomplete="current-password"
             class="w-full bg-surface-raised border border-divider rounded-xl px-4 py-3 text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent">
    </div>

    <div data-setup-target="error" class="hidden bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm"></div>

    <%= f.submit "Connect",
      class: "w-full bg-accent hover:bg-accent/90 text-white font-semibold rounded-xl px-4 py-3 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed",
      data: { setup_target: "submitButton" } %>
  <% end %>
</div>
